# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/portfoliomanager
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:4200"]

# Logging
LOG_LEVEL=INFO

# EOD Historical Data API (Optional - for real-time market data)
EOD_API_TOKEN=your-eod-api-token-here
EOD_API_BASE_URL=https://eodhd.com/api
EOD_API_TIMEOUT_SECONDS=30

# Azure AI Foundry Configuration (Required for AI/Agent features)
# Get these from your Azure AI Foundry project: https://ai.azure.com
# AI features are disabled if these are not configured
# Format: https://{resource}.services.ai.azure.com/openai/v1/
AZURE_FOUNDRY_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1/
AZURE_FOUNDRY_API_KEY=your-azure-ai-api-key-here
AZURE_FOUNDRY_MODEL_NAME=gpt-4o-mini

# Available models (JSON array) - shown in UI model picker
# supports_tools defaults to true; set false for models without function calling (e.g. DeepSeek)
AZURE_FOUNDRY_AVAILABLE_MODELS=[{"id":"gpt-5-mini","display_name":"GPT-5 Mini"},{"id":"gpt-5-nano","display_name":"GPT-5 Nano"},{"id":"gpt-4o-mini","display_name":"GPT-4o Mini"},{"id":"grok-4-fast-reasoning","display_name":"Grok 4 Fast Reasoning"},{"id":"DeepSeek-V3.2","display_name":"DeepSeek V3.2","supports_tools":false},{"id":"gpt-5.1-chat","display_name":"GPT-5.1 Chat"}]

# Tavily (Required for market intelligence tools - news, fundamentals, company/market overview)
# Get your API key from https://app.tavily.com
TAVILY_API_KEY=your-tavily-api-key-here

# OpenTelemetry Configuration (Optional - for observability)
# Leave blank for local development (defaults to Aspire Dashboard on port 18889)
# For production, set OTEL_EXPORTER_OTLP_ENDPOINT to your telemetry collector
OTEL_EXPORTER_OTLP_ENDPOINT=
OTLP_ENDPOINT=
OTEL_SERVICE_NAME=PortfolioManager.PythonAPI
OTEL_SERVICE_VERSION=1.0.0

# Azure Application Insights (Production only)
# Get connection string from Azure Portal > Application Insights > Properties
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Azure AD Authentication (Required for production)
# Use the same values as the C# API to share authentication
# Get these from Azure Portal > App Registrations > Your API App
AZURE_AD_TENANT_ID=your-tenant-id-here
AZURE_AD_CLIENT_ID=your-api-client-id-here
AZURE_AD_AUDIENCE=api://your-api-client-id-here
